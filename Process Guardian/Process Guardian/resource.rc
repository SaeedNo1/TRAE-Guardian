#include <windows.h>
#include "resource.h"
#pragma code_page(65001)

IDD_SETTINGS DIALOG 0, 0, 300, 400
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Settings"
BEGIN
    GROUPBOX "Daemon", -1, 8, 4, 284, 108
    LTEXT "Refresh/check interval (ms):", -1, 18, 20, 120, 12
    EDITTEXT IDC_SET_CHECK_INTERVAL, 140, 18, 70, 14, ES_NUMBER
    LTEXT "(process list refresh)", -1, 216, 20, 80, 12
    LTEXT "Reload interval (ms):", -1, 18, 40, 100, 12
    EDITTEXT IDC_SET_RELOAD_INTERVAL, 124, 38, 70, 14, ES_NUMBER
    CONTROL "Auto-refresh process list", IDC_SET_AUTO_REFRESH, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 18, 58, 140, 12
    LTEXT "Log size limit (MB):", -1, 18, 76, 100, 12
    EDITTEXT IDC_SET_LOG_MAX_MB, 124, 74, 70, 14, ES_NUMBER
    LTEXT "Score reset interval (days):", -1, 18, 94, 120, 12
    EDITTEXT IDC_SET_SCORE_RESET_INTERVAL, 132, 92, 70, 14, ES_NUMBER

    GROUPBOX "Protection", -1, 8, 98, 284, 90
    CONTROL "Registry protection (snapshot restore)", IDC_SET_REG_PROT, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 18, 114, 240, 12
    CONTROL "Partition protection (snapshot restore)", IDC_SET_PART_PROT, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 18, 132, 240, 12
    CONTROL "System-critical protection (system proc / MBR)", IDC_SET_SYS_PROT, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 18, 150, 240, 12
    CONTROL "AI-assisted threat evaluation", IDC_SET_AI_ASSIST, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 18, 168, 240, 12
    LTEXT "AI trigger threshold:", -1, 18, 186, 60, 12
    COMBOBOX IDC_SET_AI_THRESHOLD, 90, 184, 90, 80, CBS_DROPDOWNLIST | WS_TABSTOP | WS_VSCROLL

    GROUPBOX "Trust zone", -1, 8, 192, 284, 90
    LTEXT "One directory per line:", -1, 18, 208, 120, 12
    EDITTEXT IDC_SET_TRUSTED_ZONES, 18, 222, 264, 50, ES_MULTILINE | ES_AUTOVSCROLL | WS_VSCROLL | WS_TABSTOP

    GROUPBOX "Common processes", -1, 8, 288, 284, 80
    LTEXT "Census interval (ms):", -1, 18, 304, 90, 12
    EDITTEXT IDC_SET_CENSUS_INTERVAL, 112, 302, 70, 14, ES_NUMBER
    LTEXT "Record limit:", -1, 190, 304, 60, 12
    EDITTEXT IDC_SET_MAX_PROC_RECORDS, 252, 302, 30, 14, ES_NUMBER
    LTEXT "Manual common processes (one exe per line):", -1, 18, 320, 180, 12
    EDITTEXT IDC_SET_MANUAL_COMMON, 18, 334, 264, 28, ES_MULTILINE | ES_AUTOVSCROLL | WS_VSCROLL | WS_TABSTOP

    DEFPUSHBUTTON "OK", IDOK, 70, 372, 70, 22
    PUSHBUTTON "Cancel", IDCANCEL, 160, 372, 70, 22
END

IDD_DISKPICK DIALOG 0, 0, 320, 260
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Select Disk"
BEGIN
    CONTROL "", IDC_DISKPICK_LIST, "SysListView32",
            LVS_REPORT | LVS_SINGLESEL | WS_BORDER | WS_TABSTOP,
            8, 8, 304, 210
    DEFPUSHBUTTON "OK", IDOK, 90, 226, 80, 26
    PUSHBUTTON "Cancel", IDCANCEL, 180, 226, 80, 26
END

IDD_HEXEDIT DIALOG 0, 0, 700, 500
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Sector 0 Editor"
BEGIN
    CONTROL "", IDC_HEXEDIT_LIST, "SysListView32",
            LVS_REPORT | LVS_SINGLESEL | WS_BORDER | WS_TABSTOP,
            8, 8, 684, 370

    LTEXT "Hex value:", -1, 8, 386, 60, 14
    EDITTEXT IDC_HEXEDIT_VALUE, 70, 384, 60, 14, ES_AUTOHSCROLL
    PUSHBUTTON "Apply", IDC_HEXEDIT_APPLY, 140, 382, 60, 22
    PUSHBUTTON "Save", IDC_HEXEDIT_SAVE, 210, 382, 60, 22
    PUSHBUTTON "Reload", IDC_HEXEDIT_RELOAD, 280, 382, 60, 22
    PUSHBUTTON "MBR->GPT", IDC_HEXEDIT_MBR2GPT, 350, 382, 80, 22
    PUSHBUTTON "GPT->MBR", IDC_HEXEDIT_GPT2MBR, 440, 382, 80, 22

    PUSHBUTTON "Close", IDCANCEL, 600, 440, 80, 28
END

IDD_NEW_TASK DIALOG 0, 0, 480, 460
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Create AI Monitor Task"
BEGIN
    LTEXT "Task name:", -1, 8, 8, 80, 14
    EDITTEXT IDC_DLG_NAME_EDIT, 90, 6, 380, 16, ES_AUTOHSCROLL

    LTEXT "Targets:", -1, 8, 30, 80, 14
    CONTROL "", IDC_DLG_TARGET_LV, "SysListView32",
            LVS_REPORT | LVS_SINGLESEL | WS_BORDER | WS_TABSTOP,
            8, 48, 360, 160

    LTEXT "Type:", -1, 380, 48, 40, 14
    COMBOBOX IDC_DLG_TYPE_CB, 380, 64, 92, 80, CBS_DROPDOWNLIST
    LTEXT "Name:", -1, 380, 88, 40, 14
    EDITTEXT IDC_DLG_PROC_NAME, 380, 104, 92, 14, ES_AUTOHSCROLL
    LTEXT "PID:", -1, 380, 124, 40, 14
    EDITTEXT IDC_DLG_PID_EDIT, 380, 140, 92, 14, ES_AUTOHSCROLL
    CONTROL "Tree", IDC_DLG_TREE_CHK, "Button", BS_AUTOCHECKBOX,
            380, 160, 92, 14
    PUSHBUTTON "+ Add", IDC_DLG_ADD_BTN, 380, 184, 92, 24
    PUSHBUTTON "- Remove", IDC_DLG_DEL_BTN, 380, 212, 92, 24

    LTEXT "Start (YYYY-MM-DD HH:MM:SS):", -1, 8, 220, 200, 14
    EDITTEXT IDC_DLG_START, 210, 218, 260, 14, ES_AUTOHSCROLL
    LTEXT "End (YYYY-MM-DD HH:MM:SS):", -1, 8, 240, 200, 14
    EDITTEXT IDC_DLG_END, 210, 238, 260, 14, ES_AUTOHSCROLL

    LTEXT "AI read interval (sec, 60..86400):", -1, 8, 264, 200, 14
    EDITTEXT IDC_DLG_INTERVAL, 210, 262, 100, 14, ES_NUMBER
    LTEXT "Read bytes (1..1048576):", -1, 8, 284, 200, 14
    EDITTEXT IDC_DLG_BYTES, 210, 282, 100, 14, ES_NUMBER

    LTEXT "Tasks are managed in your browser via task_admin.exe.",
            -1, 8, 320, 460, 14

    DEFPUSHBUTTON "OK", IDC_DLG_OK, 280, 420, 80, 28
    PUSHBUTTON "Cancel", IDC_DLG_CANCEL, 380, 420, 80, 28
END

IDD_ASK_AI DIALOG 0, 0, 720, 230
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Ask AI - Process Guardian"
BEGIN
    LTEXT "Model:", -1, 8, 8, 60, 14
    EDITTEXT IDC_AI_MODEL, 70, 6, 640, 14, ES_AUTOHSCROLL

    LTEXT "Active tasks: select a task to enable chat / edit / delete", -1, 8, 28, 500, 14
    CONTROL "", IDC_AI_TASK_LIST, "SysListView32",
            LVS_REPORT | LVS_SINGLESEL | WS_BORDER | WS_TABSTOP,
            8, 44, 500, 150
    PUSHBUTTON "Talk to AI", IDC_AI_TALK, 516, 70, 120, 28
    PUSHBUTTON "Edit", IDC_AI_EDIT, 516, 104, 56, 24
    PUSHBUTTON "Delete", IDC_AI_DELETE, 580, 104, 56, 24
    PUSHBUTTON "Refresh", IDC_AI_REFRESH, 516, 136, 120, 24
    PUSHBUTTON "Change key", IDC_AI_CHANGE_KEY, 516, 168, 120, 24
    PUSHBUTTON "Global Chat", IDC_AI_GLOBAL_CHAT, 516, 200, 120, 24
    PUSHBUTTON "Close", IDCANCEL, 640, 196, 70, 26
END

IDD_ASK_CHAT DIALOG 0, 0, 660, 520
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "AI Chat - Process Guardian"
BEGIN
    LTEXT "Task: (none)", IDC_CHAT_TITLE, 8, 8, 640, 18

    CONTROL "", IDC_CHAT_OUTPUT, "RichEdit20W",
             WS_CHILD | WS_VISIBLE | WS_TABSTOP |
             ES_MULTILINE | ES_AUTOVSCROLL | ES_READONLY | WS_VSCROLL,
             8, 30, 644, 410

    EDITTEXT IDC_CHAT_INPUT, 8, 448, 550, 40,
             ES_MULTILINE | ES_AUTOVSCROLL | ES_WANTRETURN | WS_VSCROLL

    DEFPUSHBUTTON "Send", IDC_CHAT_SEND, 564, 448, 88, 28
    PUSHBUTTON "Clear memory", IDC_CHAT_CLEAR, 564, 480, 88, 24
    PUSHBUTTON "Close", IDC_CHAT_CLOSE, 564, 506, 88, 24
END

IDD_KEYSET DIALOG 0, 0, 460, 130
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Set SiliconFlow API key"
BEGIN
    LTEXT "API key (stored obfuscated in data\\api_key.dat):", -1, 8, 8, 440, 14
    EDITTEXT IDC_KEYSET_EDIT, 8, 28, 444, 22, ES_AUTOHSCROLL | ES_PASSWORD
    LTEXT "Get a key at https://cloud.siliconflow.cn/account/ak", -1, 8, 56, 440, 14
    DEFPUSHBUTTON "OK", IDC_KEYSET_OK, 270, 90, 80, 28
    PUSHBUTTON "Cancel", IDC_KEYSET_CANCEL, 372, 90, 80, 28
END